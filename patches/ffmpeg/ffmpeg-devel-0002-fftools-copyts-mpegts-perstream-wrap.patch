diff --git a/fftools/ffmpeg_demux.c b/fftools/ffmpeg_demux.c
index a0e7dfb0d9..23c3c98513 100644
--- a/fftools/ffmpeg_demux.c
+++ b/fftools/ffmpeg_demux.c
@@ -82,6 +82,15 @@ typedef struct DemuxStream {
     /// dts of the last packet read for this stream (in AV_TIME_BASE units)
     int64_t                  dts;
 
+    /* Per-stream MPEG-TS timestamp wrap continuation under -copyts. wrap_offset
+     * is the accumulated correction (in this stream's pkt time_base) added to
+     * every pts/dts so a 33-bit (pts_wrap_bits) rollover continues monotonically
+     * instead of regressing. wrap_last_dts is the previous raw input dts used to
+     * detect a backward step. Tracking this per stream (rather than via the
+     * shared Demuxer.ts_offset_discont) keeps each timeline independent. */
+    int64_t                  wrap_offset;
+    int64_t                  wrap_last_dts;
+
     const AVCodecDescriptor *codec_desc;
 
     AVDictionary            *decoder_opts;
@@ -225,14 +234,9 @@ static void ts_discontinuity_detect(Demuxer *d, InputStream *ist,
     int64_t pkt_dts = av_rescale_q_rnd(pkt->dts, pkt->time_base, AV_TIME_BASE_Q,
                                        AV_ROUND_NEAR_INF | AV_ROUND_PASS_MINMAX);
 
-    if (copy_ts && ds->next_dts != AV_NOPTS_VALUE &&
-        fmt_is_discont && ist->st->pts_wrap_bits < 60) {
-        int64_t wrap_dts = av_rescale_q_rnd(pkt->dts + (1LL<<ist->st->pts_wrap_bits),
-                                            pkt->time_base, AV_TIME_BASE_Q,
-                                            AV_ROUND_NEAR_INF|AV_ROUND_PASS_MINMAX);
-        if (FFABS(wrap_dts - ds->next_dts) < FFABS(pkt_dts - ds->next_dts)/10)
-            disable_discontinuity_correction = 0;
-    }
+    /* Under -copyts the MPEG-TS 33-bit wrap is handled per stream in
+     * ts_discontinuity_process(), which returns before reaching here, so this
+     * function only runs for the non-copyts global discontinuity path. */
 
     if (ds->next_dts != AV_NOPTS_VALUE && !disable_discontinuity_correction) {
         int64_t delta = pkt_dts - ds->next_dts;
@@ -286,8 +290,59 @@ static void ts_discontinuity_detect(Demuxer *d, InputStream *ist,
 static void ts_discontinuity_process(Demuxer *d, InputStream *ist,
                                      AVPacket *pkt)
 {
-    int64_t offset = av_rescale_q(d->ts_offset_discont, AV_TIME_BASE_Q,
-                                  pkt->time_base);
+    InputFile *ifile = &d->f;
+    DemuxStream *ds = ds_from_ist(ist);
+    int64_t offset;
+
+    /* Under -copyts, continue the MPEG-TS 33-bit timestamp wrap PER STREAM
+     * instead of folding it into the shared ts_offset_discont. libavformat's
+     * wrap_timestamp() only adds at most one epoch and stops once raw values
+     * climb back past pts_wrap_reference, so on a long run the dts regresses by
+     * 2^33 at the wrap. The old fix detected this for audio/video and shifted
+     * the *global* offset, which (a) diverges when streams cross the wrap on
+     * different packets, starving the interleaver, and (b) never reaches sparse
+     * stream-copied data (SCTE-35) or subtitle/teletext PIDs. A per-stream
+     * accumulated offset keeps every timeline monotonic and independent, fixing
+     * both the starvation and the copied-stream regression with one mechanism.
+     * Adding an exact multiple of 2^33 is wrap-correct for the MPEG-TS muxer,
+     * which masks pts/dts/pcr back to 33 bits on the wire. */
+    if (copy_ts &&
+        (ifile->ctx->iformat->flags & AVFMT_TS_DISCONT) &&
+        ist->st->pts_wrap_bits > 0 && ist->st->pts_wrap_bits < 60) {
+        int64_t wrap = 1LL << ist->st->pts_wrap_bits;
+        int64_t raw_dts = pkt->dts;
+
+        /* Detect a fresh rollover as a backward dts step of more than half a
+         * wrap versus this stream's own previous raw dts. dts is monotonic by
+         * construction (unlike pts with B-frames); a legitimate forward gap is
+         * never negative, so this cannot misfire. */
+        if (raw_dts != AV_NOPTS_VALUE && ds->wrap_last_dts != AV_NOPTS_VALUE &&
+            ds->wrap_last_dts - raw_dts > wrap / 2) {
+            int64_t back  = ds->wrap_last_dts - raw_dts;
+            int64_t wraps = (back + wrap / 2) / wrap; /* nearest N, covers multi-wrap gaps */
+            if (wraps < 1)
+                wraps = 1;
+            ds->wrap_offset = av_sat_add64(ds->wrap_offset, wraps * wrap);
+            av_log(ist, AV_LOG_DEBUG,
+                   "MPEG-TS copyts wrap (stream id=%d): +%"PRId64" wrap(s), "
+                   "offset now %"PRId64"\n",
+                   ist->st->id, wraps, ds->wrap_offset);
+        }
+        if (raw_dts != AV_NOPTS_VALUE)
+            ds->wrap_last_dts = raw_dts;
+
+        /* Same delta to pts and dts preserves their ordering and delay. */
+        if (ds->wrap_offset) {
+            if (pkt->dts != AV_NOPTS_VALUE)
+                pkt->dts = av_sat_add64(pkt->dts, ds->wrap_offset);
+            if (pkt->pts != AV_NOPTS_VALUE)
+                pkt->pts = av_sat_add64(pkt->pts, ds->wrap_offset);
+        }
+        return;
+    }
+
+    offset = av_rescale_q(d->ts_offset_discont, AV_TIME_BASE_Q,
+                          pkt->time_base);
 
     // apply previously-detected timestamp-discontinuity offset
     // (to all streams, not just audio/video)
@@ -1267,6 +1322,8 @@ static DemuxStream *demux_stream_alloc(Demuxer *d, AVStream *st)
     ds->sch_idx_stream = -1;
     ds->sch_idx_dec    = -1;
 
+    ds->wrap_last_dts  = AV_NOPTS_VALUE;
+
     ds->ist.st         = st;
     ds->ist.file       = f;
     ds->ist.index      = st->index;
